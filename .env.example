# Store Intelligence System - Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://storeintel:storeintel_pass@localhost:5432/store_intelligence
DATABASE_URL_SYNC=postgresql://storeintel:storeintel_pass@localhost:5432/store_intelligence

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
DEBUG=true

# Grok Vision API (xAI) - for staff detection
XAI_API_KEY=your_xai_api_key_here
XAI_API_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL=grok-2-vision-latest

# Pipeline Configuration
DATA_DIR=./data
OUTPUT_DIR=./output/events
YOLO_MODEL=yolo11l.pt
DETECTION_CONFIDENCE=0.25
VID_STRIDE=3
STAFF_DWELL_THRESHOLD=0.6
REENTRY_SIMILARITY_THRESHOLD=0.7
REENTRY_TTL_MINUTES=30

# Dashboard
STREAMLIT_PORT=8501
API_URL=http://localhost:8000
